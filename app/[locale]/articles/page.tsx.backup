"use client";

import React from "react";
import { notFound } from "next/navigation";
import {
    Card,
    CardContent,
    CardDescription,
    CardHeader,
    CardTitle,
} from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Calendar, Clock, User, ArrowRight } from "lucide-react";
import enMessages from "../../../messages/en.json";
import thMessages from "../../../messages/th.json";
import { getAllArticles, Article } from "@/lib/articles";

const messageMap: Record<string, Record<string, unknown>> = {
    en: enMessages,
    th: thMessages,
};

export default function Articles({ params }: { params: { locale: string } }) {
    const { locale } = params;
    const messages = messageMap[locale];

    if (!messages) {
        notFound();
    }

    const translations = {
        en: {
            title: "Real Estate Articles",
            subtitle: "Insights, tips, and market updates from our experts",
            readMore: "Read More",
            latestArticles: "Latest Articles",
            featuredArticle: "Featured Article",
            categories: "Categories",
            allArticles: "All Articles",
            marketInsights: "Market Insights",
            buyingGuide: "Buying Guide",
            rentalTips: "Rental Tips",
            investment: "Investment",
            lifestyle: "Lifestyle",
            minutesRead: "min read",
        },
        th: {
            title: "บทความอสังหาริมทรัพย์",
            subtitle:
                "ข้อมูลเชิงลึก เคล็ดลับ และอัปเดตตลาดจากผู้เชี่ยวชาญของเรา",
            readMore: "อ่านเพิ่มเติม",
            latestArticles: "บทความล่าสุด",
            featuredArticle: "บทความแนะนำ",
            categories: "หมวดหมู่",
            allArticles: "บทความทั้งหมด",
            marketInsights: "ข้อมูลตลาด",
            buyingGuide: "คู่มือการซื้อ",
            rentalTips: "เคล็ดลับการเช่า",
            investment: "การลงทุน",
            lifestyle: "ไลฟ์สไตล์",
            minutesRead: "นาทีในการอ่าน",
        },
    };

    const tLocal = (key: string) => {
        return (
            (translations[locale as "en" | "th"] as Record<string, string>)?.[
                key
            ] || key
        );
    };

    const articles = getAllArticles().map(article => ({
        id: article.slug,
        title: article.title,
        excerpt: article.excerpt,
        author: article.author,
        date: article.date,
        readTime: article.readTime,
        category: article.tags[0] || "general", // Use first tag as category
        image: article.image,
    }));

    const categories = [
        { key: "allArticles", label: tLocal("allArticles") },
        { key: "marketInsights", label: tLocal("marketInsights") },
        { key: "buyingGuide", label: tLocal("buyingGuide") },
        { key: "rentalTips", label: tLocal("rentalTips") },
        {
            id: "rental-market-trends",
            title:
                locale === "en"
                    ? "Current Trends in Bangkok's Rental Market"
                    : "แนวโน้มปัจจุบันในตลาดเช่ากรุงเทพฯ",
            excerpt:
                locale === "en"
                    ? "Stay ahead of the curve with insights into Bangkok's evolving rental property landscape."
                    : "ก้าวนำหน้าด้วยข้อมูลเชิงลึกเกี่ยวกับภูมิทัศน์อสังหาริมทรัพย์เช่ากรุงเทพฯ ที่เปลี่ยนแปลง",
            author: locale === "en" ? "Niran Kulwong" : "นิรันดร์ กุลวงศ์",
            date: "2024-01-05",
            readTime: "5",
            category: "rentalTips",
            image: "https://images.unsplash.com/photo-1560185127-6ed189bf02f4?w=800&h=400&fit=crop&cs=tinysrgb",
        },
        {
            id: "luxury-living-bangkok",
            title:
                locale === "en"
                    ? "Luxury Living in Bangkok: What to Expect"
                    : "การใช้ชีวิตหรูหราในกรุงเทพฯ: สิ่งที่ควรคาดหวัง",
            excerpt:
                locale === "en"
                    ? "Explore the premium lifestyle options available in Bangkok's luxury real estate market."
                    : "สำรวจตัวเลือกไลฟ์สไตล์ระดับพรีเมียมที่มีอยู่ในตลาดอสังหาริมทรัพย์หรูกรุงเทพฯ",
            author: locale === "en" ? "Somchai Prasert" : "สมชาย ประเสริฐ",
            date: "2023-12-28",
            readTime: "7",
            category: "lifestyle",
            image: "https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=800&h=400&fit=crop&cs=tinysrgb",
        },
        {
            id: "first-time-buyer-guide",
            title:
                locale === "en"
                    ? "First-Time Buyer's Guide to Thai Property"
                    : "คู่มือผู้ซื้อบ้านครั้งแรกสำหรับอสังหาริมทรัพย์ไทย",
            excerpt:
                locale === "en"
                    ? "A comprehensive guide for newcomers to Thailand's property market, covering legal requirements and tips."
                    : "คู่มือครบถ้วนสำหรับผู้มาใหม่ในตลาดอสังหาริมทรัพย์ไทย ครอบคลุมข้อกำหนดทางกฎหมายและเคล็ดลับ",
            author: locale === "en" ? "Siriporn Thanakit" : "ศิริพร ธนกิจ",
            date: "2023-12-20",
            readTime: "10",
            category: "buyingGuide",
            image: "https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&h=400&fit=crop&cs=tinysrgb",
        },
        {
            id: "sustainable-real-estate",
            title:
                locale === "en"
                    ? "The Rise of Sustainable Real Estate in Thailand"
                    : "การเพิ่มขึ้นของอสังหาริมทรัพย์ที่ยั่งยืนในประเทศไทย",
            excerpt:
                locale === "en"
                    ? "Learn about eco-friendly building practices and green certifications in Thailand's property sector."
                    : "เรียนรู้เกี่ยวกับแนวปฏิบัติการก่อสร้างที่เป็นมิตรกับสิ่งแวดล้อมและการรับรองสีเขียวในภาคอสังหาริมทรัพย์ไทย",
            author: locale === "en" ? "Niran Kulwong" : "นิรันดร์ กุลวงศ์",
            date: "2023-12-15",
            readTime: "6",
            category: "marketInsights",
            image: "https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=800&h=400&fit=crop&cs=tinysrgb",
        },
    ];

    const categories = [
        { key: "allArticles", label: tLocal("allArticles") },
        { key: "marketInsights", label: tLocal("marketInsights") },
        { key: "buyingGuide", label: tLocal("buyingGuide") },
        { key: "rentalTips", label: tLocal("rentalTips") },
        { key: "investment", label: tLocal("investment") },
        { key: "lifestyle", label: tLocal("lifestyle") },
    ];

    const featuredArticle = articles[0];
    const latestArticles = articles.slice(1);

    return (
        <main className="min-h-screen bg-white">
            {/* Hero Section */}
            <section className="bg-gray-900 text-white py-20 border-b border-gray-200">
                <div className="container-minimal text-center">
                    <h1 className="text-5xl md:text-6xl font-bold mb-6 tracking-tight">
                        {tLocal("title")}
                    </h1>
                    <p className="text-xl text-gray-300 max-w-2xl mx-auto">
                        {tLocal("subtitle")}
                    </p>
                </div>
            </section>

            <div className="container-minimal py-16">
                {/* Featured Article */}
                <section className="mb-16">
                    <h2 className="text-3xl md:text-4xl font-bold text-gray-900 mb-8 tracking-tight">
                        {tLocal("featuredArticle")}
                    </h2>
                    <Card className="overflow-hidden border border-gray-200 shadow-xl">
                        <div className="md:flex">
                            <div className="md:w-1/2">
                                <img
                                    src={featuredArticle.image}
                                    alt={featuredArticle.title}
                                    className="w-full h-64 md:h-full object-cover"
                                />
                            </div>
                            <div className="md:w-1/2 p-8">
                                <div className="flex items-center mb-4">
                                    <Badge className="bg-gray-900 text-white hover:bg-gray-800">
                                        {tLocal(featuredArticle.category)}
                                    </Badge>
                                </div>
                                <h3 className="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
                                    {featuredArticle.title}
                                </h3>
                                <p className="text-gray-600 mb-6 text-lg">
                                    {featuredArticle.excerpt}
                                </p>
                                <div className="flex items-center text-sm text-gray-500 mb-6 space-x-4">
                                    <div className="flex items-center">
                                        <User className="w-4 h-4 mr-1" />
                                        {featuredArticle.author}
                                    </div>
                                    <div className="flex items-center">
                                        <Calendar className="w-4 h-4 mr-1" />
                                        {new Date(
                                            featuredArticle.date,
                                        ).toLocaleDateString(
                                            locale === "en" ? "en-US" : "th-TH",
                                        )}
                                    </div>
                                    <div className="flex items-center">
                                        <Clock className="w-4 h-4 mr-1" />
                                        {featuredArticle.readTime}{" "}
                                        {tLocal("minutesRead")}
                                    </div>
                                </div>
                                <Button className="bg-gray-900 text-white hover:bg-gray-800">
                                    {tLocal("readMore")}
                                    <ArrowRight className="w-4 h-4 ml-2" />
                                </Button>
                            </div>
                        </div>
                    </Card>
                </section>

                {/* Categories */}
                <section className="mb-12">
                    <h3 className="text-2xl font-bold text-gray-900 mb-6">
                        {tLocal("categories")}
                    </h3>
                    <div className="flex flex-wrap gap-3">
                        {categories.map((category) => (
                            <Button
                                key={category.key}
                                variant="outline"
                                className="border-gray-300 text-gray-700 hover:bg-gray-100 hover:border-gray-900"
                            >
                                {category.label}
                            </Button>
                        ))}
                    </div>
                </section>

                {/* Latest Articles */}
                <section>
                    <h2 className="text-3xl md:text-4xl font-bold text-gray-900 mb-8 tracking-tight">
                        {tLocal("latestArticles")}
                    </h2>
                    <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {latestArticles.map((article) => (
                            <Card
                                key={article.id}
                                className="border border-gray-200 hover:border-gray-900 transition-colors bg-white overflow-hidden"
                            >
                                <div className="aspect-video overflow-hidden">
                                    <img
                                        src={article.image}
                                        alt={article.title}
                                        className="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                                    />
                                </div>
                                <CardContent className="p-6">
                                    <div className="flex items-center mb-3">
                                        <Badge className="bg-gray-100 text-gray-700 hover:bg-gray-200 text-xs">
                                            {tLocal(article.category)}
                                        </Badge>
                                    </div>
                                    <h3 className="text-xl font-semibold text-gray-900 mb-3 line-clamp-2">
                                        {article.title}
                                    </h3>
                                    <p className="text-gray-600 mb-4 text-sm line-clamp-3">
                                        {article.excerpt}
                                    </p>
                                    <div className="flex items-center text-xs text-gray-500 mb-4 space-x-3">
                                        <div className="flex items-center">
                                            <User className="w-3 h-3 mr-1" />
                                            {article.author}
                                        </div>
                                        <div className="flex items-center">
                                            <Calendar className="w-3 h-3 mr-1" />
                                            {new Date(
                                                article.date,
                                            ).toLocaleDateString(
                                                locale === "en"
                                                    ? "en-US"
                                                    : "th-TH",
                                            )}
                                        </div>
                                        <div className="flex items-center">
                                            <Clock className="w-3 h-3 mr-1" />
                                            {article.readTime}m
                                        </div>
                                    </div>
                                    <Button
                                        variant="outline"
                                        size="sm"
                                        className="w-full border-gray-300 text-gray-700 hover:bg-gray-100 hover:border-gray-900"
                                    >
                                        {tLocal("readMore")}
                                        <ArrowRight className="w-3 h-3 ml-1" />
                                    </Button>
                                </CardContent>
                            </Card>
                        ))}
                    </div>
                </section>
            </div>
        </main>
    );
}
